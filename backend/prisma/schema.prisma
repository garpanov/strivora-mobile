generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat    = "cjs"
}

datasource db {
  provider = "postgresql"
}

///////////         ENUMS         ///////////

enum LifeStatus {
  Family 
  Job 
  Study
}

enum AlertType {
  Tips
  Progress
  Update
}

enum TaskPriority {
  Low
  Medium
  High
}

enum TaskStatus {
  InProgress
  Done
  Expired
}

enum AISection {
  YesterdayTasks
  MonthFinances
  YesterdayAnalise
}

enum LanguageSettings {
  English
  Ukrainian
  Russian
}

enum ExpenseCategory {
  Food
  Entertainment
  Development
}

///////////         MODELS         ///////////

model User {
  id Int @id @default(autoincrement())
  name String
  email String @unique
  password String
  birthdate DateTime?
  lifeStatus LifeStatus?
  salary Decimal?

  refreshTokens RefreshToken[]
  alerts Alert[]
  tasks Task[]
  historyExpenses ExpenseHistory[]
  tipsAI TipsAI[]
  settings Settings?

  dateCreated DateTime @default(now())
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Alert {
  id Int @id @default(autoincrement())
  name String
  description String 
  type AlertType
  processed Boolean @default(false)

  dateSend DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  userId Int
}

model Task {
  id Int @id @default(autoincrement())
  name String
  description String?
  priority TaskPriority
  status TaskStatus @default(InProgress)

  dateCreated DateTime @default(now())
  dateStart DateTime @default(now())
  dateEnd DateTime

  user User @relation(fields: [userId], references: [id])
  userId Int
}

model ExpenseHistory {
  id Int @id @default(autoincrement())
  amount Decimal
  name String
  category ExpenseCategory

  dateCreated DateTime @default(now())
  date DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  userId Int
}

model TipsAI {
  id Int @id @default(autoincrement())
  description String
  section AISection

  dateCreated DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  userId Int
}

model Settings {
  id Int @id @default(autoincrement())
  language LanguageSettings @default(English)
  country String?
  alertPhone Boolean @default(true)

  user User @relation(fields: [userId], references: [id])
  userId Int @unique
}
